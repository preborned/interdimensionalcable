<!-- 
=================================================================================
 iCable Development Build - Configuration
=================================================================================
 This file contains the bare configuration and customization options for the
 iCable.
=================================================================================
-->
<config>
    <!-- Data Sources -->
    <settings>
        <!-- URL to your XMLTV file. Leave empty to use JSON. -->
        <xmltvUrl>http://localhost:8000/api/xmltv.xml</xmltvUrl>
        <!-- URL to your JSON guide file. Leave empty to use XMLTV. -->
        <jsonUrl></jsonUrl>
        <!-- URL to your M3U playlist for automatic stream mapping. (Recommended) -->
        <m3uUrl>http://localhost:8000/api/channels.m3u</m3uUrl>
        
        <!-- OpenWeather API for weather functionality. (Get a free key at https://openweathermap.org/api). -->
        <openWeatherApiKey>48ec9014a51d8caf7b66463ac3b1dbaf</openWeatherApiKey>
        
        <!-- TMDb API for custom posters. (Get a free key at https://www.themoviedb.org) -->
        <tmdbApiKey>9dc4d7c6c1e2867bb21d4a32714bf692</tmdbApiKey>
    </settings>

    <!-- Player Settings (Legacy - Will be removed) -->
    <player>
        <!-- Fallback URL for channels without a defined stream. -->
        <url></url>
        <!-- Optional custom hotlink override for fallback channels. -->
        <hotlinkUrl></hotlinkUrl>
    </player>
    
    <!-- Feature Toggles & Appearance -->
    <features>
        <enableLogo>true</enableLogo>
        <logoUrl>images/icable.png</logoUrl> 
        <enableWeather>true</enableWeather>
    </features>

    <!-- Custom messages for the bottom message box. -->
    <messages>
        <message>Welcome to the Interdimensional Cable Guide!</message>
        <message>Press 'M' to open the main menu.</message>
    </messages>

    <!-- Color Customization -->
    <colors>
        <primaryBgStart>#1d2b4b</primaryBgStart>
        <primaryBgEnd>#0c1428</primaryBgEnd>
        <secondaryBg>#2a3a5e</secondaryBg>
        <tertiaryBg>#4d648d</tertiaryBg>
        <accent>#00aaff</accent>
        <text>#f0f0f0</text>
        <liveBg>#78909c</liveBg>
        <pastBg>#263238</pastBg>
    </colors>

    <!-- Manual Channel Mappings (HLS and YouTube compatible) -->
    <streamMappings>
        <!-- HLS Example -->
        <stream channelId="1" type="hls">http://localhost:8000/stream/channels/47e82e66-e77f-4a9f-9ac9-4e1c5aa3aead?streamMode=hls</stream>
        <!-- YouTube Example -->
        <stream channelId="2" type="youtube">jfKfPfyJRdk</stream>
    </streamMappings>

    <!-- Custom Channels -->
    <customChannels>
        <channel id="1" number="1" name="BBC" logo="https://placehold.co/100x100/ffeb3b/000000?text=BBC">
            <programTitle>BBC - Not What You Think</programTitle>
            <episodeNum>S03E09</episodeNum>
            <description>This isn't BBC News, it's not exactly the BBC you're thinking of.</description>
        </channel>
        <channel id="2" number="2" name="TOON" logo="https://placehold.co/100x100/e0e0e0/000000?text=Cartoons">
            <programTitle>Tom And Jerry</programTitle>
            <episodeNum>S56E12</episodeNum>
            <description>Tom the Cat and Jerry the Mouse are back at it again. What else is new.</description>
        </channel>
    </customChannels>
</config>
